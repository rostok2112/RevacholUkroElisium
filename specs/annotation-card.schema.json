{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/revachol/annotation-card.schema.json",
  "title": "AnnotationCard",
  "type": "object",
  "required": [
    "line_id",
    "translation_uk",
    "quick_note",
    "quality"
  ],
  "properties": {
    "line_id": {
      "type": "string"
    },
    "translation_uk": {
      "type": "string"
    },
    "literal_gloss": {
      "type": "string"
    },
    "quick_note": {
      "type": "string",
      "maxLength": 220
    },
    "deep_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "text"
        ],
        "properties": {
          "kind": {
            "enum": [
              "idiom",
              "reference",
              "sarcasm",
              "lore",
              "politics",
              "skill_voice",
              "tone",
              "cultural_equivalent",
              "translation_choice",
              "audio"
            ]
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "ukrainian_cultural_equivalents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "glossary_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "semantic_accuracy": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "voice_preservation": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "ukrainian_naturalness": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "spoiler_safety": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "needs_human_review": {
          "type": "boolean"
        }
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "provider_name": {
          "type": "string"
        },
        "provider_kind": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "offline": {
          "type": "boolean"
        },
        "deterministic": {
          "type": "boolean"
        }
      }
    },
    "provider_debug": {
      "type": "object",
      "properties": {
        "provider_name": {
          "type": "string"
        },
        "provider_role": {
          "type": "string"
        },
        "provider_version": {
          "type": "string"
        },
        "prompt_pack_id": {
          "type": "string"
        },
        "prompt_pack_version": {
          "type": "string"
        },
        "required_output_fields_seen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_priorities_seen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "player_facing_language_default": {
          "type": "string"
        },
        "internal_guidance_language": {
          "type": "string"
        },
        "policy_note_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_refs_seen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "prompt_pack": {
      "type": "object",
      "properties": {
        "pack_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "required_output_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quality_priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_note_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "player_facing_language_default": {
          "type": "string"
        },
        "internal_guidance_language": {
          "type": "string"
        }
      }
    }
  }
}
