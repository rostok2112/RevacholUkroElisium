{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/revachol/annotation-card.schema.json",
  "title": "AnnotationCard",
  "type": "object",
  "required": [
    "line_id",
    "translation_uk",
    "quick_note",
    "quality"
  ],
  "properties": {
    "line_id": {
      "type": "string"
    },
    "translation_uk": {
      "type": "string"
    },
    "literal_gloss": {
      "type": "string"
    },
    "quick_note": {
      "type": "string",
      "maxLength": 220
    },
    "deep_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "text"
        ],
        "properties": {
          "kind": {
            "enum": [
              "idiom",
              "sarcasm",
              "lore",
              "politics",
              "skill_voice",
              "tone",
              "cultural_equivalent",
              "translation_choice",
              "audio"
            ]
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "ukrainian_cultural_equivalents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "glossary_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "semantic_accuracy": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "voice_preservation": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "ukrainian_naturalness": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "spoiler_safety": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "needs_human_review": {
          "type": "boolean"
        }
      }
    }
  }
}
