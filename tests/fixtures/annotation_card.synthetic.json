{
  "line_id": "synthetic.e2e.001",
  "translation_uk": "\u041a\u043e\u043c\u0456\u0442\u0435\u0442 \u043f\u043e\u0445\u043e\u0432\u0430\u0432 \u0433\u043e\u0434\u0438\u043d\u043d\u0438\u043a, \u0430 \u043f\u043e\u0442\u0456\u043c \u0437\u0432\u0438\u043d\u0443\u0432\u0430\u0442\u0438\u0432 \u0447\u0430\u0441, \u0449\u043e \u0442\u043e\u0439 \u0441\u043f\u0456\u0437\u043d\u0438\u0432\u0441\u044f.",
  "literal_gloss": "The committee hid the clock and blamed time for lateness.",
  "quick_note": "\u0421\u0443\u0445\u0430 \u0431\u044e\u0440\u043e\u043a\u0440\u0430\u0442\u0438\u0447\u043d\u0430 \u0456\u0440\u043e\u043d\u0456\u044f: \u043b\u044e\u0434\u0438 \u0441\u0430\u043c\u0456 \u0441\u0442\u0432\u043e\u0440\u044e\u044e\u0442\u044c \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0443 \u0456 \u0432\u0434\u0430\u044e\u0442\u044c, \u0449\u043e \u0432\u0438\u043d\u0435\u043d \u0441\u0432\u0456\u0442.",
  "deep_notes": [
    {
      "kind": "idiom",
      "text": "\u0420\u044f\u0434\u043e\u043a \u0433\u0440\u0430\u0454 \u043d\u0430 \u043e\u0431\u0440\u0430\u0437\u0456 \u0441\u0430\u0431\u043e\u0442\u0430\u0436\u0443 \u0432\u043b\u0430\u0441\u043d\u043e\u0433\u043e \u0432\u0438\u043c\u0456\u0440\u044e\u0432\u0430\u043d\u043d\u044f \u0447\u0430\u0441\u0443."
    },
    {
      "kind": "reference",
      "text": "\u0426\u0435 \u0441\u0438\u043d\u0442\u0435\u0442\u0438\u0447\u043d\u0430 \u0430\u043b\u044e\u0437\u0456\u044f \u043d\u0430 \u043f\u043e\u0440\u043e\u0436\u043d\u044e \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u0447\u0443 \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u0430\u043b\u044c\u043d\u0456\u0441\u0442\u044c, \u043d\u0435 \u0446\u0438\u0442\u0430\u0442\u0430 \u0437 \u0433\u0440\u0438."
